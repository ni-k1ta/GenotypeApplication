<Window x:Class="GenotypeApplication.Application_windows.ColorBrewerConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GenotypeApplication.Application_windows"
        xmlns:conv="clr-namespace:GenotypeApplication.MVVM.Converters"
        xmlns:dd="urn:gong-wpf-dragdrop"
        mc:Ignorable="d"
        Title="Clusters color definition"
        Height="290"
        Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:ColorNameToBrushConverter x:Key="ColorNameToBrushConverter" />
    </Window.Resources>

    <Grid Margin="5,5,5,3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <GroupBox Header="Select color scheme"
                  Padding="1"
                  Width="375.22"
                  Grid.Row="0">
            <ComboBox ItemsSource="{Binding AvailableSchemes}"
                      SelectedItem="{Binding SelectedScheme}"
                      DisplayMemberPath="Family"
                      Width="100" 
                      Margin="2,0,0,0"/>
        </GroupBox>

        <GroupBox Header="Cluster order (order defines bottom-to-top display)"
                  Grid.Row="1"
                  Width="375.22">

            <ListBox ItemsSource="{Binding Items}"
                     dd:DragDrop.IsDragSource="True"
                     dd:DragDrop.IsDropTarget="True"
                     dd:DragDrop.UseDefaultDragAdorner="True"
                     dd:DragDrop.DefaultDragAdornerOpacity="0.8"
                     dd:DragDrop.DropTargetAdornerBrush="DarkGray"
                     dd:DragDrop.DragAdornerTranslation="340,0"
                     HorizontalContentAlignment="Stretch"
                     BorderThickness="0"
                     Background="Transparent">
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </ControlTemplate>
                </ListBox.Template>

                <ListBox.Resources>
                    <Style TargetType="{x:Type ScrollBar}"
                           BasedOn="{StaticResource ThinScrollBar}" />
                </ListBox.Resources>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding"
                                Value="2" />
                        <Setter Property="Margin"
                                Value="3" />
                        <Setter Property="BorderBrush"
                                Value="LightGray" />
                        <Setter Property="BorderThickness"
                                Value="1" />
                        <Setter Property="Background"
                                Value="White" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="3">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter Property="Background"
                                                    Value="#F0F0F0" />
                                            <Setter Property="BorderBrush"
                                                    Value="#999" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="≡"
                                       FontSize="16"
                                       Foreground="Gray"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Cursor="SizeAll" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding ClusterIndex}"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="5,0" />

                            <TextBlock Grid.Column="2"
                                       Text="{Binding ColorName}"
                                       VerticalAlignment="Center"
                                       Foreground="SlateGray"
                                       Margin="5,0" />

                            <Border Grid.Column="3"
                                    Width="50"
                                    Height="24"
                                    BorderBrush="Gray"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Margin="5,0"
                                    Background="{Binding ColorName, Converter={StaticResource ColorNameToBrushConverter}}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,5,0,0"
                    VerticalAlignment="Bottom">
            <Button Content="Save"
                    Margin="0"
                    Style="{StaticResource Rounded}"
                    Command="{Binding SaveColorBrewerConfigurationAsyncCommand}" />
        </StackPanel>
    </Grid>
</Window>
