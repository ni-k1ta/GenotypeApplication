<Window x:Class="GenotypeApplication.Application_windows.DistructColorsConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GenotypeApplication.Application_windows"
        xmlns:conv="clr-namespace:GenotypeApplication.MVVM.Converters"
        xmlns:dd="urn:gong-wpf-dragdrop"
        mc:Ignorable="d"
        Title="Clusters color definition"
        Height="290"
        Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:ColorNameToBrushConverter x:Key="ColorNameToBrushConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:GrayscaleToBrushConverter x:Key="GrayscaleToBrushConverter" />
    </Window.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Header="Assign a color to each cluster (order defines bottom-to-top display)"
                  Grid.Row="0">

            <ListBox ItemsSource="{Binding Items}"
                     dd:DragDrop.IsDragSource="True"
                     dd:DragDrop.IsDropTarget="True"
                     dd:DragDrop.UseDefaultDragAdorner="True"
                     dd:DragDrop.DefaultDragAdornerOpacity="0.8"
                     dd:DragDrop.DropTargetAdornerBrush="DarkGray"
                     dd:DragDrop.DragAdornerTranslation="340,0"
                     HorizontalContentAlignment="Stretch"
                     BorderThickness="0"
                     Background="Transparent">
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </ControlTemplate>
                </ListBox.Template>

                <ListBox.Resources>
                    <Style TargetType="{x:Type ScrollBar}"
                           BasedOn="{StaticResource ThinScrollBar}" />
                </ListBox.Resources>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding"
                                Value="2" />
                        <Setter Property="Margin"
                                Value="3" />
                        <Setter Property="BorderBrush"
                                Value="LightGray" />
                        <Setter Property="BorderThickness"
                                Value="1" />
                        <Setter Property="Background"
                                Value="White" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="3">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter Property="Background"
                                                    Value="#F0F0F0" />
                                            <Setter Property="BorderBrush"
                                                    Value="#999" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding ClusterIndex}"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="5,0" />

                            <TextBlock Grid.Column="0"
                                       Text="≡"
                                       FontSize="16"
                                       Foreground="Gray"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Cursor="SizeAll" />

                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding DataContext.AvailableColors, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                      SelectedItem="{Binding ColorName}"
                                      Margin="5,0"
                                      Visibility="{Binding DataContext.IsGrayscale, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                            <Grid Grid.Column="2"
                                  Visibility="{Binding DataContext.IsGrayscale, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVis}}">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Slider Grid.Column="0"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="{Binding GrayscaleValue}"
                                        Width="150"
                                        VerticalAlignment="Center"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="False" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding GrayscaleValue, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"
                                         MinWidth="0"
                                         Width="45"
                                         Margin="8,0,0,0"
                                         VerticalAlignment="Center" />
                            </Grid>

                            <Border Grid.Column="3"
                                    Width="50"
                                    Height="24"
                                    BorderBrush="Gray"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Margin="5,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{Binding ColorName, Converter={StaticResource ColorNameToBrushConverter}}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsGrayscale, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                         Value="True">
                                                <Setter Property="Background"
                                                        Value="{Binding GrayscaleValue, Converter={StaticResource GrayscaleToBrushConverter}}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0"
                    VerticalAlignment="Bottom">
            <Button Content="Save"
                    Margin="0,0,5,5"
                    Style="{StaticResource Rounded}"
                    Command="{Binding SaveConfigurationPaletteAsyncCommand}"/>
        </StackPanel>
    </Grid>
</Window>
