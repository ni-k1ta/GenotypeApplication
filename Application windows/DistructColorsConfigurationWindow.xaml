<Window x:Class="GenotypeApplication.Application_windows.DistructColorsConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GenotypeApplication.Application_windows"
        xmlns:conv="clr-namespace:GenotypeApplication.MVVM.Converters"
        xmlns:dd="urn:gong-wpf-dragdrop"
        mc:Ignorable="d"
        Title="DistructColorsConfigurationWindow"
        Height="350"
        Width="350">

    <Window.Resources>
        <conv:ColorNameToBrushConverter x:Key="ColorNameToBrushConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:GrayscaleToBrushConverter x:Key="GrayscaleToBrushConverter" />
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Assign a color to each cluster (order defines bottom-to-top display):"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10" />

        <ListBox  Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  dd:DragDrop.IsDragSource="True"
                  dd:DragDrop.IsDropTarget="True"
                  dd:DragDrop.UseDefaultDragAdorner="True"
                  dd:DragDrop.DefaultDragAdornerOpacity="0.7"
                  dd:DragDrop.DropTargetAdornerBrush="DarkGray"
                  dd:DragDrop.DragAdornerTranslation="300,0"
                  HorizontalContentAlignment="Stretch"
                  BorderThickness="0"
                  Background="Transparent">
            <ListBox.Template>
                <ControlTemplate TargetType="ListBox">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsPresenter />
                    </ScrollViewer>
                </ControlTemplate>
            </ListBox.Template>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding"
                            Value="4" />
                    <Setter Property="Margin"
                            Value="0,1" />
                    <Setter Property="BorderBrush"
                            Value="LightGray" />
                    <Setter Property="BorderThickness"
                            Value="1" />
                    <Setter Property="Background"
                            Value="White" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="3">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#F0F0F0" />
                                        <Setter Property="BorderBrush"
                                                Value="#999" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding ClusterIndex}"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="5,0" />

                        <TextBlock Grid.Column="0"
                                   Text="≡"
                                   FontSize="16"
                                   Foreground="Gray"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Cursor="SizeAll" />

                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding DataContext.AvailableColors, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                  SelectedItem="{Binding ColorName}"
                                  Margin="5,0"
                                  Visibility="{Binding DataContext.IsGrayscale, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    Visibility="{Binding DataContext.IsGrayscale, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVis}}">
                            <Slider Minimum="0"
                                    Maximum="1"
                                    Value="{Binding GrayscaleValue}"
                                    Width="180"
                                    VerticalAlignment="Center"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="False" />
                            <TextBox Text="{Binding GrayscaleValue, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"
                                     Width="50"
                                     Margin="8,0,0,0"
                                     VerticalAlignment="Center" />
                        </StackPanel>

                        <Border Grid.Column="3"
                                Width="24"
                                Height="24"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="2"
                                Margin="5,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background"
                                            Value="{Binding ColorName, Converter={StaticResource ColorNameToBrushConverter}}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsGrayscale, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                     Value="True">
                                            <Setter Property="Background"
                                                    Value="{Binding GrayscaleValue, Converter={StaticResource GrayscaleToBrushConverter}}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Save"
                    Margin="0,0,8,0"
                    Style="{StaticResource Rounded}" />
        </StackPanel>
    </Grid>
</Window>
