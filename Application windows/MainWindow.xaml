                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox x:Name="inputAtopLabelsFilePathTextBox"
                                                             Text="{Binding INFILE_LABEL_ATOP, UpdateSourceTrigger=PropertyChanged}"
                                                             FontWeight="Light"
                                                             Grid.Column="0"
                                                             HorizontalAlignment="Left"
                                                             Width="130" />
                                                    <Button x:Name="selectInputAtopLabelsFileButton"
                                                            Content="Select"
                                                            Margin="10,0,0,0"
                                                            Grid.Column="1"
                                                            HorizontalAlignment="Right"
                                                            Style="{StaticResource Rounded}"
                                                            Command="{Binding SelectLabelsAtopFileCommand}" />
                                                </Grid>
                                            </GroupBox>

                                            <GroupBox x:Name="inputBelowLabelsFileSelectionGroupBox"
                                                      Header="Input file of labels below the figure"
                                                      HorizontalAlignment="Stretch"
                                                      IsEnabled="{Binding PRINT_LABEL_BELOW, UpdateSourceTrigger=PropertyChanged}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox x:Name="inputBelowLabelsFilePathTextBox"
                                                             Text="{Binding INFILE_LABEL_BELOW, UpdateSourceTrigger=PropertyChanged}"
                                                             FontWeight="Light"
                                                             Grid.Column="0"
                                                             HorizontalAlignment="Left"
                                                             Width="130" />
                                                    <Button x:Name="selectInputBelowLabelsFileButton"
                                                            Content="Select"
                                                            Margin="10,0,0,0"
                                                            Grid.Column="1"
                                                            HorizontalAlignment="Right"
                                                            Style="{StaticResource Rounded}"
                                                            Command="{Binding SelectLabelsBelowFileCommand}" />
                                                </Grid>
                                            </GroupBox>
                                        </StackPanel>
                                        <StackPanel Orientation="Vertical"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Right">
                                            <GroupBox x:Name="clustersPermutationsInputFileSelectionGroupBox"
                                                      Header="Configure the cluster color palette"
                                                      HorizontalAlignment="Stretch">

                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center">
                                                    <Button Content="Configure"
                                                            Style="{StaticResource Rounded}"
                                                            Width="90"
                                                            Margin="0,0,5,0"
                                                            Command="{Binding ConfigureColorPaletteCommand}" />

                                                    <Label Content="or"
                                                           VerticalAlignment="Center" />

                                                    <Button Content="Select file"
                                                            Style="{StaticResource Rounded}"
                                                            Margin="5,0,0,0"
                                                            Width="90"
                                                            Command="{Binding SelectClustPermFileCommand}" />
                                                </StackPanel>
                                            </GroupBox>

                                            <DockPanel LastChildFill="False">
                                                <Label x:Name="predefinedPopsLabel"
                                                       Content="Number of predefined pops"
                                                       DockPanel.Dock="Left" />
                                                <xctk:IntegerUpDown x:Name="predefinedPopsIntUpDown"
                                                                    Minimum="0"
                                                                    Maximum="27000000"
                                                                    Increment="1"
                                                                    DockPanel.Dock="Right"
                                                                    Margin="0,0,1,0"
                                                                    Value="{Binding NUMPOPS, UpdateSourceTrigger=PropertyChanged}" />
                                            </DockPanel>

                                            <DockPanel LastChildFill="False">
                                                <Label x:Name="predefinedIndividsLabel"
                                                       Content="Number of predefined individuals"
                                                       DockPanel.Dock="Left" />
                                                <xctk:IntegerUpDown x:Name="predefinedIndividsIntUpDown"
                                                                    Minimum="0"
                                                                    Maximum="27000000"
                                                                    Increment="1"
                                                                    DockPanel.Dock="Right"
                                                                    Margin="0,0,1,0"
                                                                    Value="{Binding NUMINDS, UpdateSourceTrigger=PropertyChanged}" />
                                            </DockPanel>
                                        </StackPanel>
                                    </Grid>
                                </GroupBox>

                                <GroupBox x:Name="figureAppearanceGroupBox"
                                          Header="Figure appearance"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="{Binding ConfigurationEnabled, UpdateSourceTrigger=PropertyChanged}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Vertical"
                                                    Grid.Column="0"
                                                    VerticalAlignment="Bottom">
                                            <DockPanel LastChildFill="False">
                                                <Label x:Name="fontSizeLabel"
                                                       Content="Size of font"
                                                       DockPanel.Dock="Left" />
                                                <xctk:DoubleUpDown x:Name="fontSizeDoubleUpDown"
                                                                   Minimum="0"
                                                                   Maximum="100"
                                                                   Increment="0.1"
                                                                   DockPanel.Dock="Right"
                                                                   Value="{Binding FONTHEIGHT, UpdateSourceTrigger=PropertyChanged}" />
                                            </DockPanel>
                                            <DockPanel LastChildFill="False">
                                                <Label x:Name="figureHeightLabel"
                                                       Content="Height of the figure"
                                                       DockPanel.Dock="Left" />
                                                <xctk:DoubleUpDown x:Name="figureHeightDoubleUpDown"
                                                                   Minimum="0"
                                                                   Maximum="1000"
                                                                   Increment="0.1"
                                                                   DockPanel.Dock="Right"
                                                                   Value="{Binding BOXHEIGHT, UpdateSourceTrigger=PropertyChanged}" />
                                            </DockPanel>
                                            <DockPanel LastChildFill="False">
                                                <Label x:Name="textAbovePlacementDistLabel"
                                                       Content="Distance above plot to place text"
                                                       DockPanel.Dock="Left" />
                                                <xctk:DoubleUpDown x:Name="textAbovePlacementDistDoubleUpDown"
                                                                   Minimum="0"
                                                                   Maximum="100"
                                                                   Increment="0.1"
                                                                   DockPanel.Dock="Right"
                                                                   Value="{Binding DIST_ABOVE, UpdateSourceTrigger=PropertyChanged}" />
                                            </DockPanel>
                                        </StackPanel>

                                        <StackPanel Orientation="Vertical"
                                                    Grid.Column="1"
                                                    Margin="5,0,0,0"
                                                    HorizontalAlignment="Stretch">
                                            <DockPanel LastChildFill="False">
                                                <Label x:Name="individWidthLabel"
                                                       Content="Width of an individual"
                                                       DockPanel.Dock="Left" />
                                                <xctk:DoubleUpDown x:Name="individWidthDoubleUpDown"
                                                                   Minimum="0"
                                                                   Maximum="100"
                                                                   Increment="0.1"
                                                                   DockPanel.Dock="Right"
                                                                   Value="{Binding INDIVWIDTH, UpdateSourceTrigger=PropertyChanged}" />
                                            </DockPanel>
                                            <DockPanel LastChildFill="False">
                                                <Label x:Name="textBelowPlacementDistLabel"
                                                       Content="Distance below plot to place text"
                                                       DockPanel.Dock="Left" />
                                                <xctk:DoubleUpDown x:Name="textBelowPlacementDistDoubleUpDown"
                                                                   Minimum="-100"
                                                                   Maximum="100"
                                                                   Increment="0.1"
                                                                   DockPanel.Dock="Right"
                                                                   Value="{Binding DIST_BELOW, UpdateSourceTrigger=PropertyChanged}" />
                                            </DockPanel>
                                            <Button Margin="0,5,0,0"
                                                    HorizontalAlignment="Center"
                                                    Width="210"
                                                    Content="Determine the optimal values"
                                                    Style="{StaticResource Rounded}"
                                                    Command="{Binding DetermineOptimalValuesCommand}" />
                                        </StackPanel>
                                    </Grid>
                                </GroupBox>
                            </StackPanel>

                            <GroupBox Grid.Column="1"
                                      x:Name="pregeneratedImageGroupBox"
                                      Header="Pre-generated image"
                                      Width="366"
                                      Height="259">
                                <Grid>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <GroupBox x:Name="pregeneratedImageKNumSelectionGroupBox"
                                              Header="Select 'K' number"
                                              HorizontalAlignment="Stretch"
                                              Grid.Row="0">
                                        <DockPanel LastChildFill="False">
                                            <ComboBox x:Name="pregeneratedImageKNumComboBox"
                                                      DockPanel.Dock="Left"
                                                      ItemsSource="{Binding KForPreviewItems}"
                                                      SelectedItem="{Binding SelectedKForPreview, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button x:Name="generateButton"
                                                    Content="Generate"
                                                    DockPanel.Dock="Right"
                                                    Style="{StaticResource Rounded}"
                                                    Command="{Binding GeneratePreviewCommand}" />
                                        </DockPanel>
                                    </GroupBox>

                                    <Border Margin="0,5,0,0"
                                            Grid.Row="1">

                                        <Image x:Name="PsPreview"
                                               Source="{Binding PreviewImage}"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality" />

                                    </Border>
                                </Grid>
                            </GroupBox>
                        </Grid>


                        <!--</StackPanel>-->

                        <DockPanel LastChildFill="False"
                                   Grid.Column="0"
                                   Grid.Row="3"
                                   Grid.ColumnSpan="2">
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Left">
                                <Label x:Name="distructStartKLabel"
                                       Content="'K' from"
                                       Height="23" />
                                <xctk:IntegerUpDown x:Name="distructStartKIntUpDown"
                                                    Value="{Binding KFrom, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                                                    Maximum="{Binding PredefinedCLUMPPKEnd, Mode=OneWay}"
                                                    Minimum="{Binding PredefinedCLUMPPKStart, Mode=OneWay}" />
                                <Label x:Name="distructToLabel"
                                       Content="to"
                                       Height="23" />
                                <xctk:IntegerUpDown x:Name="distructEndKIntUpDown"
                                                    Value="{Binding KTo, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                                                    Maximum="{Binding PredefinedCLUMPPKEnd, Mode=OneWay}"
                                                    Minimum="{Binding PredefinedCLUMPPKStart, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Right">

                                <Button x:Name="saveDistructOptionsButton"
                                        Content="Save"
                                        Margin="0,0,58,0"
                                        Style="{StaticResource Rounded}"
                                        Command="{Binding SaveChangesAsyncCommand}" />
                                <Button x:Name="startDistructExecutionButton"
                                        Content="Start"
                                        Margin="0,0,5,0"
                                        Style="{StaticResource Rounded}"
                                        Command="{Binding StartDistructAsyncCommand}" />
                                <Button x:Name="stopDistructExecutionButton"
                                        Content="Stop"
                                        Margin="0,0,0,0"
                                        Style="{StaticResource Rounded}"
                                        Command="{Binding StopDistructCommand}" />
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
