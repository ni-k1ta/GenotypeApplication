<Window x:Class="GenotypeApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GenotypeApplication"
        xmlns:behaviors="clr-namespace:GenotypeApplication.MVVM.List_box"
        xmlns:conv="clr-namespace:GenotypeApplication.MVVM.Converters"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="MainWindow"
        MinHeight="850"
        MinWidth="1200"
        Width="1211"
        Height="852"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        DataContext="{Binding MainWindowVM}">

    <Window.Resources>
        <conv:EmptyStringToPlaceholderStringConverter x:Key="EmptyStringToPlaceholderStringConverter" />

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded"
                    Value="{Binding IsExpanded, Mode=TwoWay}" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <conv:InverseBooleanConverter x:Key="InverseBool" />
    </Window.Resources>

    <Grid Margin="5,5,5,0">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"
                              MinWidth="255" />
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GridSplitter Grid.Column="1"
                      Grid.RowSpan="3"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="Transparent" />
        <GridSplitter Grid.Row="1"
                      Grid.ColumnSpan="3"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      ResizeDirection="Rows" />

        <TreeView x:Name="projectOverviewTreeView"
                  Grid.Row="0"
                  Grid.Column="0"
                  Margin="5,5,5,3"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Top"
                  MinWidth="250"
                  Height="587"
                  ItemsSource="{Binding ProjectExplorer.RootNodes}">

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded"
                            Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="HorizontalContentAlignment"
                            Value="Left" />
                    <Setter Property="VerticalContentAlignment"
                            Value="Center" />
                </Style>
            </TreeView.ItemContainerStyle>

            <TreeView.Resources>
                <Style TargetType="{x:Type ScrollBar}"
                       BasedOn="{StaticResource ThinScrollBar}" />
            </TreeView.Resources>

            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁"
                                   Margin="0,0,4,0"
                                   Visibility="{Binding IsDirectory, 
                            Converter={StaticResource BoolToVisConverter}}" />
                        <TextBlock Text="{Binding Name}" />
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <StackPanel Grid.Row="2"
                    Grid.Column="0"
                    Height="Auto"
                    Width="Auto"
                    Orientation="Vertical"
                    Margin="5,0,5,0">
            <GroupBox HorizontalAlignment="Stretch"
                      Header="Structure progress"
                      Margin="0"
                      Padding="2">
                <Grid DataContext="{Binding StructureTabControlVM}">
                    <ProgressBar Height="25"
                                 Value="{Binding StructureProgress}">

                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StructureStopped}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>

                    </ProgressBar>


                    <TextBlock Text="{Binding StructureProgressText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="11" />
                </Grid>
            </GroupBox>

            <GroupBox HorizontalAlignment="Stretch"
                      Header="Structure Harvester progress"
                      Margin="0"
                      Padding="2">
                <Grid DataContext="{Binding StructureHarvesterTabControlVM}">
                    <ProgressBar Height="25"
                                 IsIndeterminate="{Binding StructureHarvesterIsIndeterminate}"
                                 Value="{Binding StructureHarvesterProgress}" />
                    <TextBlock Text="{Binding StructureHarvesterProgressText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="11" />
                </Grid>
            </GroupBox>

            <GroupBox HorizontalAlignment="Stretch"
                      Header="CLUMPP progress"
                      Margin="0"
                      Padding="2">
                <Grid DataContext="{Binding CLUMPPTabControlVM}">
                    <ProgressBar Height="25"
                                 Value="{Binding CLUMPPProgress}">

                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CLUMPPStopped}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>

                    </ProgressBar>


                    <TextBlock Text="{Binding CLUMPPProgressText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="11" />
                </Grid>
            </GroupBox>

            <GroupBox HorizontalAlignment="Stretch"
                      Header="Distruct progress"
                      Margin="0"
                      Padding="2">
                <Grid DataContext="{Binding DistructTabControlVM}">
                    <ProgressBar Height="25"
                                 Value="{Binding DistructProgress}">

                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DistructStopped}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>

                    </ProgressBar>


                    <TextBlock Text="{Binding DistructProgressText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="11" />
                </Grid>
            </GroupBox>

        </StackPanel>

        <ListBox x:Name="logListBox"
                 Grid.Column="2"
                 Grid.Row="2"
                 Width="915"
                 VerticalAlignment="Stretch"
                 Margin="5,3,5,1"
                 ItemsSource="{Binding Logger.Entries}"
                 ScrollViewer.CanContentScroll="True"
                 behaviors:ListBoxAutoScrollBehavior.ScrollSource="{Binding Logger}"
                 VirtualizingPanel.IsVirtualizing="True">
            <!--behaviors:ListBoxAutoScrollBehavior.Enabled="True"-->

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel VirtualizationMode="Recycling" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.Resources>
                <Style TargetType="{x:Type ScrollBar}"
                       BasedOn="{StaticResource ThinScrollBar}" />
            </ListBox.Resources>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding ToDisplayString}"
                               FontFamily="Consolas"
                               FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Level}"
                                                 Value="Error">
                                        <Setter Property="Foreground"
                                                Value="Red" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}"
                                                 Value="Warning">
                                        <Setter Property="Foreground"
                                                Value="Orange" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

        <TabControl x:Name="programsInteractionTabControl"
                    Grid.Column="2"
                    Grid.Row="0"
                    Margin="5,5,5,5"
                    HorizontalAlignment="Stretch"
                    MinWidth="915.2">
            <TabItem x:Name="structureTabItem"
                     Header="Structure"
                     HorizontalAlignment="Stretch"
                     DataContext="{Binding StructureTabControlVM}">

                <TabItem.Resources>
                    <Style TargetType="{x:Type ScrollBar}"
                           BasedOn="{StaticResource ThinScrollBar}" />
                </TabItem.Resources>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <GroupBox x:Name="loadDataFileGroupBox"
                                  Header="Load data file"
                                  Grid.Column="0"
                                  Grid.Row="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="loadDataFileButton"
                                        Content="Load"
                                        Grid.Column="0"
                                        Margin="5,0,10,0"
                                        Style="{StaticResource Rounded}"
                                        Command="{Binding LoadDataFileCommand}" />
                                <TextBox x:Name="dataFileNameTextBox"
                                         Text="{Binding DataFileName, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="True"
                                         Grid.Column="1"
                                         FontWeight="Light"
                                         Margin="0,0,5,0" />

                                <TextBlock Text="Data file name"
                                           Grid.Column="1"
                                           Foreground="LightGray"
                                           Margin="5,0,0,1"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=dataFileNameTextBox}"
                                                             Value="">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </GroupBox>

                        <GroupBox x:Name="parameterSetsSelection"
                                  Header="Select parameters set"
                                  Grid.Column="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="parameterSetsComboBox"
                                          Grid.Column="0"
                                          Margin="5,0,10,0"
                                          ItemsSource="{Binding SetModelsComboBoxList}"
                                          SelectedItem="{Binding SelectedComboBoxSet, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="Name" />
                                <TextBox x:Name="parametersSetNameTextBox"
                                         Grid.Column="1"
                                         FontWeight="Light"
                                         Text="{Binding SetName, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,5,0" />

                                <TextBlock Text="Data set name"
                                           Grid.Column="1"
                                           Foreground="LightGray"
                                           Margin="5,0,0,1"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=parametersSetNameTextBox}"
                                                             Value="">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </GroupBox>

                        <GroupBox x:Name="runLenghtGroupBox"
                                  Header="Run lenght"
                                  Grid.Column="0"
                                  Grid.Row="1"
                                  IsEnabled="{Binding ConfigurationEnable, UpdateSourceTrigger=PropertyChanged}">
                            <StackPanel Orientation="Vertical">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Label x:Name="burninLengthLabel"
                                           Content="Length of burnin period"
                                           Grid.Column="0" />
                                    <xctk:IntegerUpDown x:Name="burninLengthIntUpDown"
                                                        Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="131072"
                                                        Increment="1"
                                                        HorizontalAlignment="Right"
                                                        Value="{Binding BurnInParam, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Label x:Name="mcmcRepsNumLabel"
                                           Content="Number of MCMC reps after burnin"
                                           Grid.Column="0" />
                                    <xctk:IntegerUpDown x:Name="mcmcRepsNumIntUpDown"
                                                        Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="131072"
                                                        Increment="1"
                                                        HorizontalAlignment="Right"
                                                        Value="{Binding NumRepsParam, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox x:Name="AlleleFreqModelGroupBox"
                                  Header="Allele frequency model"
                                  Grid.Column="1"
                                  Grid.Row="1"
                                  HorizontalAlignment="Stretch"
                                  IsEnabled="{Binding ConfigurationEnable, UpdateSourceTrigger=PropertyChanged}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <CheckBox x:Name="correlatedAlleleFreqsCheckBox"
                                          Content="Allele frequencies are correlated"
                                          Grid.Column="0"
                                          Grid.Row="0"
                                          IsChecked="{Binding FreqsCorrParam, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox x:Name="setLambdaCheckBox"
                                          Content="Set lambda"
                                          Grid.Column="1"
                                          Grid.Row="0"
                                          IsChecked="{Binding NotInferLambdaParam, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox x:Name="inferLambdaCheckBox"
                                          Content="Infer lambda"
                                          Grid.Column="2"
                                          Grid.Row="0"
                                          IsChecked="{Binding InferLambdaParam, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox x:Name="fstSameValueCheckBox"
                                          Content="Assume same value of Fst for all subpopulations"
                                          Grid.Column="0"
                                          Grid.Row="1"
                                          Margin="15,0,0,0"
                                          IsChecked="{Binding OnefstParam, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding FreqsCorrParam, UpdateSourceTrigger=PropertyChanged}" />
                                <xctk:DoubleUpDown x:Name="lambdaDoubleUpDown"
                                                   Grid.Column="1"
                                                   Grid.Row="1"
                                                   Minimum="-27000"
                                                   Maximum="27000"
                                                   Increment="0.1"
                                                   Margin="15,0,10,0"
                                                   Value="{Binding PopSpecificLambdaValueParam, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Orientation="Horizontal"
                                            Grid.Column="2"
                                            Grid.Row="1"
                                            IsEnabled="{Binding InferLambdaParam, UpdateSourceTrigger=PropertyChanged}">
                                    <Label x:Name="lambdaInitLabel"
                                           Content="Lambda initialization"
                                           Margin="10,0,3.8,0" />
                                    <xctk:DoubleUpDown x:Name="lambdaInitDoubleUpDown"
                                                       Minimum="-27000"
                                                       Maximum="27000"
                                                       Increment="0.1"
                                                       Value="{Binding InferLambdaValueParam, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            Grid.Row="2"
                                            Grid.Column="0"
                                            IsEnabled="{Binding FreqsCorrParam, UpdateSourceTrigger=PropertyChanged}">
                                    <Label x:Name="priorMeanLabel"
                                           Content="Prior mean"
                                           Margin="30,0,0,0" />
                                    <xctk:DoubleUpDown x:Name="priorMeanDoubleUpDown"
                                                       Maximum="100"
                                                       Minimum="0"
                                                       Increment="0.01"
                                                       FormatString="0.##"
                                                       Value="{Binding FPriorMeanParam, UpdateSourceTrigger=PropertyChanged}" />
                                    <Label x:Name="priorSdLabel"
                                           Content="Prior sd"
                                           Margin="10,0,0,0"
                                           HorizontalAlignment="Right" />
                                    <xctk:DoubleUpDown x:Name="priorSdDoubleUpDown"
                                                       Maximum="100"
                                                       Minimum="0"
                                                       Increment="0.01"
                                                       FormatString="0.##"
                                                       HorizontalAlignment="Right"
                                                       Value="{Binding FPriorSDParam, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <CheckBox x:Name="popLambdaSeparationCheckBox"
                                          Content="Separate lambda by population"
                                          Grid.Row="2"
                                          Grid.Column="2"
                                          Margin="15,0,0,0"
                                          IsChecked="{Binding PopSpecificLambdaParam, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding InferLambdaParam, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </GroupBox>

                        <GroupBox x:Name="ancestryModelGroupBox"
                                  Header="Ancestry model"
                                  Grid.Row="2"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  HorizontalAlignment="Stretch"
                                  IsEnabled="{Binding ConfigurationEnable, UpdateSourceTrigger=PropertyChanged}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <CheckBox x:Name="noneAdmixtureModelCheckBox"
                                          Content="Assume the model without admixture"
                                          Grid.Column="0"
                                          Grid.Row="0"
                                          Grid.ColumnSpan="2"
                                          IsChecked="{Binding NoAdmixParam, UpdateSourceTrigger=PropertyChanged}" />
                                <GroupBox x:Name="linkageModelGroupBox"
                                          Grid.Column="0"
                                          Margin="10,0,0,0"
                                          Grid.Row="1"
                                          IsEnabled="{Binding DataFileFormatModel.MapDistances, UpdateSourceTrigger=PropertyChanged}">
                                    <GroupBox.Header>
                                        <CheckBox x:Name="linkageModelCheckBox"
                                                  Content="Use the linkage model"
                                                  IsChecked="{Binding LinkageParam, UpdateSourceTrigger=PropertyChanged}" />
                                    </GroupBox.Header>

                                    <StackPanel Orientation="Vertical"
                                                IsEnabled="{Binding LinkageParam}">
                                        <CheckBox x:Name="phaseFolowsMarkovCheckBox"
                                                  Content="The phase info follows a Markov model"
                                                  Margin="12,0,0,0"
                                                  IsChecked="{Binding MarkovPhaseParam, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding DataFileFormatModel.PHASEINFO, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox x:Name="printResultsBySiteCheckBox"
                                                  Content="Print site by site results"
                                                  Margin="12,0,0,0"
                                                  IsChecked="{Binding SiteBySiteParam, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox x:Name="correctPhaseDataCheckBox"
                                                  Content="Data are in correct phase"
                                                  Margin="12,0,0,0"
                                                  IsChecked="{Binding PhasedParam, UpdateSourceTrigger=PropertyChanged}" />

                                        <DockPanel Margin="27,0,0,0"
                                                   LastChildFill="False">
                                            <Label x:Name="logMinLabel"
                                                   Content="Log10rmin"
                                                   Margin="0,0,10,0"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="logMinDoubleUpDown"
                                                               DockPanel.Dock="Right"
                                                               Maximum="1000"
                                                               Minimum="-1000"
                                                               Increment="0.1"
                                                               Value="{Binding Log10rMinParam, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>
                                        <DockPanel Margin="27,0,0,0"
                                                   LastChildFill="False">
                                            <Label x:Name="logMaxLabel"
                                                   Content="Log10rmax"
                                                   Margin="0,0,10,0"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="logMaxDoubleUpDown"
                                                               HorizontalAlignment="Right"
                                                               Maximum="1000"
                                                               Minimum="-1000"
                                                               Increment="0.1"
                                                               DockPanel.Dock="Right"
                                                               Value="{Binding Log10rMaxParam, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>
                                        <DockPanel Margin="27,5,0,0"
                                                   LastChildFill="False">
                                            <Label x:Name="logPropSdLabel"
                                                   Content="Log10rpropsd"
                                                   Margin="0,0,10,0"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="logPropSdDoubleUpDown"
                                                               HorizontalAlignment="Right"
                                                               Maximum="1000"
                                                               Minimum="-1000"
                                                               Increment="0.1"
                                                               DockPanel.Dock="Right"
                                                               Value="{Binding Log10rPropSDParam, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>
                                        <DockPanel Margin="27,0,0,0"
                                                   LastChildFill="False">
                                            <Label x:Name="logStartLabel"
                                                   Content="Log10rstart"
                                                   Margin="0,0,10,0"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="logStartDoubleUpDown"
                                                               HorizontalAlignment="Right"
                                                               Maximum="1000"
                                                               Minimum="-1000"
                                                               Increment="0.1"
                                                               DockPanel.Dock="Right"
                                                               Value="{Binding Log10rStartParam, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>
                                    </StackPanel>
                                </GroupBox>

                                <StackPanel Orientation="Vertical"
                                            Grid.Row="1"
                                            Grid.Column="1">
                                    <GroupBox x:Name="useLocationInfoGroupBox"
                                              Grid.Column="1"
                                              Grid.Row="1"
                                              Margin="0,0,0,0"
                                              IsEnabled="{Binding LocPriorEnable, UpdateSourceTrigger=PropertyChanged}">
                                        <GroupBox.Header>
                                            <CheckBox x:Name="useLocationInfoCheckBox"
                                                      Content="Use location info to improve weak data"
                                                      IsChecked="{Binding LocPriorParam, UpdateSourceTrigger=PropertyChanged}" />
                                        </GroupBox.Header>

                                        <StackPanel Orientation="Vertical"
                                                    IsEnabled="{Binding LocPriorParam, UpdateSourceTrigger=PropertyChanged}">
                                            <CheckBox x:Name="popConsiderCheckBox"
                                                      Content="Consider the population for each locus"
                                                      Margin="12,0,0,0"
                                                      IsChecked="{Binding LocIsPopParam, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="{Binding LocIsPopParamEnable, UpdateSourceTrigger=PropertyChanged}" />
                                            <DockPanel LastChildFill="False"
                                                       Margin="27,0,0,0">
                                                <Label x:Name="etaInitLabel"
                                                       Content="Initial value η"
                                                       DockPanel.Dock="Left" />
                                                <xctk:IntegerUpDown x:Name="etaInitIntUpDown"
                                                                    DockPanel.Dock="Right"
                                                                    Minimum="0"
                                                                    Maximum="100"
                                                                    Increment="1"
                                                                    Value="{Binding LocPriorInitParam, UpdateSourceTrigger=PropertyChanged}" />
                                            </DockPanel>
                                            <DockPanel LastChildFill="False"
                                                       Margin="27,0,0,0">
                                                <Label x:Name="etaMaxLabel"
                                                       Content="Max value η"
                                                       DockPanel.Dock="Left" />
                                                <xctk:IntegerUpDown x:Name="etaMaxIntUpDown"
                                                                    DockPanel.Dock="Right"
                                                                    Minimum="0"
                                                                    Maximum="100"
                                                                    Increment="1"
                                                                    Value="{Binding MaxLocPriorParam, UpdateSourceTrigger=PropertyChanged}" />
                                            </DockPanel>
                                        </StackPanel>
                                    </GroupBox>

                                    <CheckBox x:Name="trainingPopFlagCheckBox"
                                              Content="Use POPFLAG for training"
                                              Margin="9,0,0,0"
                                              IsChecked="{Binding PFromPopFlagOnlyParam, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding DataFileFormatModel.PopFlag, UpdateSourceTrigger=PropertyChanged}" />

                                    <GroupBox x:Name="usePriorPopInfoGroupBox"
                                              Margin="0,0,0,0"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="{Binding DataFileFormatModel.POPDATA, UpdateSourceTrigger=PropertyChanged}">
                                        <GroupBox.Header>
                                            <CheckBox x:Name="usePriorPopInfoCheckBox"
                                                      Content="Use prior population information"
                                                      IsChecked="{Binding UsePopInfoParam, UpdateSourceTrigger=PropertyChanged}" />
                                        </GroupBox.Header>

                                        <StackPanel IsEnabled="{Binding UsePopInfoEnable, UpdateSourceTrigger=PropertyChanged}">
                                            <DockPanel LastChildFill="False">
                                                <Label x:Name="gensbackLabel"
                                                       Content="Gensback"
                                                       DockPanel.Dock="Left" />
                                                <xctk:IntegerUpDown x:Name="gensbackIntUpDown"
                                                                    DockPanel.Dock="Right"
                                                                    Minimum="0"
                                                                    Maximum="32738"
                                                                    Increment="1"
                                                                    Value="{Binding GensBackParam, UpdateSourceTrigger=PropertyChanged}" />
                                            </DockPanel>
                                            <DockPanel LastChildFill="False">
                                                <Label x:Name="migpriorLabel"
                                                       Content="Migprior"
                                                       DockPanel.Dock="Left" />
                                                <xctk:DoubleUpDown x:Name="migpriorDoubleUpDown"
                                                                   DockPanel.Dock="Right"
                                                                   Minimum="0"
                                                                   Maximum="1"
                                                                   Increment="0.01"
                                                                   FormatString="0.##"
