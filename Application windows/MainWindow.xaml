                                                Style="{StaticResource Rounded}" />
                                    </StackPanel>
                                </GroupBox>
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                Grid.Column="0"
                                Grid.Row="2">
                        <StackPanel Orientation="Vertical">
                            <GroupBox x:Name="dataSettingsGroupBox"
                                      Header="Data settings">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Vertical"
                                                Grid.Column="0">
                                        <GroupBox x:Name="inputBelowLabelsFileSelectionGroupBox"
                                                  Header="Input file of labels below the figure"
                                                  HorizontalAlignment="Stretch">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBox x:Name="inputBelowLabelsFilePathTextBox"
                                                         Text="File path"
                                                         FontWeight="Light"
                                                         Grid.Column="0"
                                                         HorizontalAlignment="Left" />
                                                <Button x:Name="selectInputBelowLabelsFileButton"
                                                        Content="Select"
                                                        Margin="10,0,0,0"
                                                        Grid.Column="1"
                                                        HorizontalAlignment="Right"
                                                        Style="{StaticResource Rounded}" />
                                            </Grid>
                                        </GroupBox>

                                        <GroupBox x:Name="inputAtopLabelsFileSelectionGroupBox"
                                                  Header="Input file of labels atop the figure"
                                                  HorizontalAlignment="Stretch">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBox x:Name="inputAtopLabelsFilePathTextBox"
                                                         Text="File path"
                                                         FontWeight="Light"
                                                         Grid.Column="0"
                                                         HorizontalAlignment="Left" />
                                                <Button x:Name="selectInputAtopLabelsFileButton"
                                                        Content="Select"
                                                        Margin="10,0,0,0"
                                                        Grid.Column="1"
                                                        HorizontalAlignment="Right"
                                                        Style="{StaticResource Rounded}" />
                                            </Grid>
                                        </GroupBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical"
                                                Grid.Column="1"
                                                HorizontalAlignment="Right">
                                        <GroupBox x:Name="clustersPermutationsInputFileSelectionGroupBox"
                                                  Header="Input file of permutation of clusters to print">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBox x:Name="clustersPermutationsInputFilePathTextBox"
                                                         Text="File path"
                                                         FontWeight="Light"
                                                         Grid.Column="0"
                                                         HorizontalAlignment="Left" />
                                                <Button x:Name="selectClustersPermutationsInputFileButton"
                                                        Content="Select"
                                                        Margin="10,0,0,0"
                                                        Grid.Column="1"
                                                        HorizontalAlignment="Left"
                                                        Style="{StaticResource Rounded}" />
                                            </Grid>
                                        </GroupBox>

                                        <DockPanel LastChildFill="False">
                                            <Label x:Name="predefinedPopsLabel"
                                                   Content="Number of predefined pops"
                                                   DockPanel.Dock="Left" />
                                            <xctk:IntegerUpDown x:Name="predefinedPopsIntUpDown"
                                                                Minimum="0"
                                                                Maximum="27000000"
                                                                Increment="1"
                                                                DockPanel.Dock="Right"
                                                                Margin="0,0,1,0" />
                                        </DockPanel>

                                        <DockPanel LastChildFill="False">
                                            <Label x:Name="predefinedIndividsLabel"
                                                   Content="Number of predefined individuals"
                                                   DockPanel.Dock="Left" />
                                            <xctk:IntegerUpDown x:Name="predefinedIndividsIntUpDown"
                                                                Minimum="0"
                                                                Maximum="27000000"
                                                                Increment="1"
                                                                DockPanel.Dock="Right"
                                                                Margin="0,0,1,0" />
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <GroupBox x:Name="figureAppearanceGroupBox"
                                      Header="Figure appearance"
                                      HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Vertical"
                                                Grid.Column="0"
                                                VerticalAlignment="Bottom">
                                        <DockPanel LastChildFill="False">
                                            <Label x:Name="fontSizeLabel"
                                                   Content="Size of font"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="fontSizeDoubleUpDown"
                                                               Minimum="0"
                                                               Maximum="100"
                                                               Increment="0.1"
                                                               DockPanel.Dock="Right" />
                                        </DockPanel>
                                        <DockPanel LastChildFill="False">
                                            <Label x:Name="figureHeightLabel"
                                                   Content="Height of the figure"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="figureHeightDoubleUpDown"
                                                               Minimum="0"
                                                               Maximum="1000"
                                                               Increment="0.1"
                                                               DockPanel.Dock="Right" />
                                        </DockPanel>
                                        <DockPanel LastChildFill="False">
                                            <Label x:Name="textAbovePlacementDistLabel"
                                                   Content="Distance above plot to place text"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="textAbovePlacementDistDoubleUpDown"
                                                               Minimum="0"
                                                               Maximum="100"
                                                               Increment="0.1"
                                                               DockPanel.Dock="Right" />
                                        </DockPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Vertical"
                                                Grid.Column="1"
                                                VerticalAlignment="Bottom"
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Stretch">
                                        <DockPanel LastChildFill="False">
                                            <Label x:Name="individWidthLabel"
                                                   Content="Width of an individual"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="individWidthDoubleUpDown"
                                                               Minimum="0"
                                                               Maximum="100"
                                                               Increment="0.1"
                                                               DockPanel.Dock="Right" />
                                        </DockPanel>
                                        <DockPanel LastChildFill="False">
                                            <Label x:Name="textBelowPlacementDistLabel"
                                                   Content="Distance below plot to place text"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="textBelowPlacementDistDoubleUpDown"
                                                               Minimum="-100"
                                                               Maximum="100"
                                                               Increment="0.1"
                                                               DockPanel.Dock="Right" />
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>
                        </StackPanel>

                        <GroupBox x:Name="pregeneratedImageGroupBox"
                                  Header="Pre-generated image">
                            <StackPanel Orientation="Vertical"
                                        VerticalAlignment="Stretch">

                                <GroupBox x:Name="pregeneratedImageKNumSelectionGroupBox"
                                          Header="Select 'K' number"
                                          HorizontalAlignment="Stretch">
                                    <DockPanel LastChildFill="False">
                                        <ComboBox x:Name="pregeneratedImageKNumComboBox"
                                                  DockPanel.Dock="Left" />
                                        <Button x:Name="generateButton"
                                                Content="Generate"
                                                DockPanel.Dock="Right"
                                                Style="{StaticResource Rounded}" />
                                    </DockPanel>
                                </GroupBox>

                                <TextBox Height="161.8"
                                         Width="341.2"
                                         Margin="0,5,0,0" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>

                    <DockPanel LastChildFill="False"
                               Grid.Column="0"
                               Grid.Row="3">
                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Left">
                            <Label x:Name="distructStartKLabel"
                                   Content="'K' from"
                                   Height="23" />
                            <xctk:IntegerUpDown x:Name="distructStartKIntUpDown" />
                            <Label x:Name="distructToLabel"
                                   Content="to"
                                   Height="23" />
                            <xctk:IntegerUpDown x:Name="distructEndKIntUpDown" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Right">
                            <Button x:Name="saveDistructOptionsButton"
                                    Content="Save"
                                    Margin="0,0,58,0"
                                    Style="{StaticResource Rounded}" />
                            <Button x:Name="startDistructExecutionButton"
                                    Content="Start"
                                    Margin="0,0,5,0"
                                    Style="{StaticResource Rounded}" />
                            <Button x:Name="stopDistructExecutionButton"
                                    Content="Stop"
                                    Margin="0,0,0,0"
                                    Style="{StaticResource Rounded}" />
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
