<Window x:Class="GenotypeApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GenotypeApplication"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="MainWindow"
        MinHeight="600"
        MinWidth="800"
        Width="1215"
        Height="800"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="5">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>


        <TreeView x:Name="projectOverviewTreeView"
                  Grid.Row="0"
                  Grid.Column="0"
                  Margin="5"
                  MinWidth="250"
                  MinHeight="583.9">
            <TreeViewItem Header="Project name" />
        </TreeView>

        <TextBox x:Name="logTextBox"
                 Grid.Column="1"
                 Grid.Row="1"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 Margin="5,10,5,0" />

        <TabControl x:Name="programsInteractionTabControl"
                    Grid.Column="1"
                    Grid.Row="0"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    MinWidth="915.2">
            <TabItem x:Name="structureTabItem"
                     Header="Structure"
                     HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <GroupBox x:Name="loadDataFileGroupBox"
                              Header="Load data file"
                              Grid.Column="0"
                              Grid.Row="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="loadDataFileButton"
                                    Content="Load"
                                    Grid.Column="0"
                                    Margin="5,0,10,0"
                                    Style="{StaticResource Rounded}"
                                    Command="{Binding LoadDataFileCommand}"/>
                            <TextBox x:Name="dataFileNameTextBox"
                                     IsReadOnly="True"
                                     Grid.Column="1"
                                     FontWeight="Light"
                                     Text="Data file name"
                                     Margin="0,0,5,0" />
                        </Grid>
                    </GroupBox>

                    <GroupBox x:Name="parameterSetsSelection"
                              Header="Select parameters set"
                              Grid.Column="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="parameterSetsComboBox"
                                      Grid.Column="0"
                                      Margin="5,0,10,0" />
                            <TextBox x:Name="parametersSetNameTextBox"
                                     Grid.Column="1"
                                     FontWeight="Light"
                                     Text="Set name"
                                     Margin="0,0,5,0" />
                        </Grid>
                    </GroupBox>

                    <GroupBox x:Name="runLenghtGroupBox"
                              Header="Run lenght"
                              Grid.Column="0"
                              Grid.Row="1">
                        <StackPanel Orientation="Vertical">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Label x:Name="burninLengthLabel"
                                       Content="Length of burnin period"
                                       Grid.Column="0" />
                                <xctk:IntegerUpDown x:Name="burninLengthIntUpDown"
                                                    Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="131072"
                                                    Increment="1"
                                                    HorizontalAlignment="Right" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Label x:Name="mcmcRepsNumLabel"
                                       Content="Number of MCMC reps after burnin"
                                       Grid.Column="0" />
                                <xctk:IntegerUpDown x:Name="mcmcRepsNumIntUpDown"
                                                    Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="131072"
                                                    Increment="1"
                                                    HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="AlleleFreqModelGroupBox"
                              Header="Allele frequency model"
                              Grid.Column="1"
                              Grid.Row="1"
                              HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <CheckBox x:Name="correlatedAlleleFreqsCheckBox"
                                      Content="Allele frequencies are correlated"
                                      Grid.Column="0"
                                      Grid.Row="0" />
                            <CheckBox x:Name="setLambdaCheckBox"
                                      Content="Set lambda"
                                      Grid.Column="1"
                                      Grid.Row="0" />
                            <CheckBox x:Name="inferLambdaCheckBox"
                                      Content="Infer lambda"
                                      Grid.Column="2"
                                      Grid.Row="0" />

                            <CheckBox x:Name="fstSameValueCheckBox"
                                      Content="Assume same value of Fst for all subpopulations"
                                      Grid.Column="0"
                                      Grid.Row="1"
                                      Margin="15,0,0,0" />
                            <xctk:DoubleUpDown x:Name="lambdaDoubleUpDown"
                                               Grid.Column="1"
                                               Grid.Row="1"
                                               Minimum="-27000"
                                               Maximum="27000"
                                               Increment="0.1"
                                               Margin="15,0,10,0" />
                            <StackPanel Orientation="Horizontal"
                                        Grid.Column="2"
                                        Grid.Row="1">
                                <Label x:Name="lambdaInitLabel"
                                       Content="Lambda initialization"
                                       Margin="10,0,3.8,0" />
                                <xctk:DoubleUpDown x:Name="lambdaInitDoubleUpDown"
                                                   Minimum="-27000"
                                                   Maximum="27000"
                                                   Increment="0.1"
                                                   Value="1" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        Grid.Row="2"
                                        Grid.Column="0">
                                <Label x:Name="priorMeanLabel"
                                       Content="Prior mean"
                                       Margin="30,0,0,0" />
                                <xctk:DoubleUpDown x:Name="priorMeanDoubleUpDown"
                                                   Maximum="100"
                                                   Minimum="0"
                                                   Increment="0.01"
                                                   FormatString="0.##"
                                                   Value="1" />
                                <Label x:Name="priorSdLabel"
                                       Content="Prior sd"
                                       Margin="10,0,0,0"
                                       HorizontalAlignment="Right" />
                                <xctk:DoubleUpDown x:Name="priorSdDoubleUpDown"
                                                   Maximum="100"
                                                   Minimum="0"
                                                   Increment="0.01"
                                                   FormatString="0.##"
                                                   HorizontalAlignment="Right" />
                            </StackPanel>

                            <CheckBox x:Name="popLambdaSeparationCheckBox"
                                      Content="Separate lambda by population"
                                      Grid.Row="2"
                                      Grid.Column="2"
                                      Margin="15,0,0,0" />
                        </Grid>
                    </GroupBox>

                    <GroupBox x:Name="ancestryModelGroupBox"
                              Header="Ancestry model"
                              Grid.Row="2"
                              Grid.Column="0"
                              Grid.ColumnSpan="2"
                              HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <CheckBox x:Name="noneAdmixtureModelCheckBox"
                                      Content="Assume the model without admixture"
                                      Grid.Column="0"
                                      Grid.Row="0"
                                      Grid.ColumnSpan="2" />
                            <GroupBox x:Name="linkageModelGroupBox"
                                      Grid.Column="0"
                                      Margin="10,0,0,0"
                                      Grid.Row="1">
                                <GroupBox.Header>
                                    <CheckBox x:Name="linkageModelCheckBox"
                                              Content="Use the linkage model" />
                                </GroupBox.Header>

                                <StackPanel Orientation="Vertical">
                                    <CheckBox x:Name="phaseFolowsMarkovCheckBox"
                                              Content="The phase info follows a Markov model"
                                              Margin="12,0,0,0" />
                                    <CheckBox x:Name="printResultsBySiteCheckBox"
                                              Content="Print site by site results"
                                              Margin="12,0,0,0" />
                                    <CheckBox x:Name="correctPhaseDataCheckBox"
                                              Content="Data are in correct phase"
                                              Margin="12,0,0,0" />

                                    <DockPanel Margin="27,0,0,0"
                                               LastChildFill="False">
                                        <Label x:Name="logMinLabel"
                                               Content="Log10rmin"
                                               Margin="0,0,10,0"
                                               DockPanel.Dock="Left" />
                                        <xctk:DoubleUpDown x:Name="logMinDoubleUpDown"
                                                           DockPanel.Dock="Right"
                                                           Maximum="1000"
                                                           Minimum="-1000"
                                                           Increment="0.1" />
                                    </DockPanel>
                                    <DockPanel Margin="27,0,0,0"
                                               LastChildFill="False">
                                        <Label x:Name="logMaxLabel"
                                               Content="Log10rmax"
                                               Margin="0,0,10,0"
                                               DockPanel.Dock="Left" />
                                        <xctk:DoubleUpDown x:Name="logMaxDoubleUpDown"
                                                           HorizontalAlignment="Right"
                                                           Maximum="1000"
                                                           Minimum="-1000"
                                                           Increment="0.1"
                                                           DockPanel.Dock="Right" />
                                    </DockPanel>
                                    <DockPanel Margin="27,5,0,0"
                                               LastChildFill="False">
                                        <Label x:Name="logPropSdLabel"
                                               Content="Log10rpropsd"
                                               Margin="0,0,10,0"
                                               DockPanel.Dock="Left" />
                                        <xctk:DoubleUpDown x:Name="logPropSdDoubleUpDown"
                                                           HorizontalAlignment="Right"
                                                           Maximum="1000"
                                                           Minimum="-1000"
                                                           Increment="0.1"
                                                           DockPanel.Dock="Right" />
                                    </DockPanel>
                                    <DockPanel Margin="27,0,0,0"
                                               LastChildFill="False">
                                        <Label x:Name="logStartLabel"
                                               Content="Log10rstart"
                                               Margin="0,0,10,0"
                                               DockPanel.Dock="Left" />
                                        <xctk:DoubleUpDown x:Name="logStartDoubleUpDown"
                                                           HorizontalAlignment="Right"
                                                           Maximum="1000"
                                                           Minimum="-1000"
                                                           Increment="0.1"
                                                           DockPanel.Dock="Right" />
                                    </DockPanel>
                                </StackPanel>
                            </GroupBox>

                            <StackPanel Orientation="Vertical"
                                        Grid.Row="1"
                                        Grid.Column="1">
                                <GroupBox x:Name="useLocationInfoGroupBox"
                                          Grid.Column="1"
                                          Grid.Row="1"
                                          Margin="0,0,0,0">
                                    <GroupBox.Header>
                                        <CheckBox x:Name="useLocationInfoCheckBox"
                                                  Content="Use location info to improve weak data" />
                                    </GroupBox.Header>

                                    <StackPanel Orientation="Vertical">
                                        <CheckBox x:Name="popConsiderCheckBox"
                                                  Content="Consider the population for each locus"
                                                  Margin="12,0,0,0" />
                                        <DockPanel LastChildFill="False"
                                                   Margin="27,0,0,0">
                                            <Label x:Name="etaInitLabel"
                                                   Content="Initial value η"
                                                   DockPanel.Dock="Left" />
                                            <xctk:IntegerUpDown x:Name="etaInitIntUpDown"
                                                                DockPanel.Dock="Right"
                                                                Minimum="0"
                                                                Maximum="100"
                                                                Increment="1" />
                                        </DockPanel>
                                        <DockPanel LastChildFill="False"
                                                   Margin="27,0,0,0">
                                            <Label x:Name="etaMaxLabel"
                                                   Content="Max value η"
                                                   DockPanel.Dock="Left" />
                                            <xctk:IntegerUpDown x:Name="etaMaxIntUpDown"
                                                                DockPanel.Dock="Right"
                                                                Minimum="0"
                                                                Maximum="100"
                                                                Increment="1" />
                                        </DockPanel>
                                    </StackPanel>
                                </GroupBox>

                                <CheckBox x:Name="trainingPopFlagCheckBox"
                                          Content="Use POPFLAG for training"
                                          Margin="9,0,0,0" />

                                <GroupBox x:Name="usePriorPopInfoGroupBox"
                                          Margin="0,0,0,0"
                                          HorizontalAlignment="Stretch">
                                    <GroupBox.Header>
                                        <CheckBox x:Name="usePriorPopInfoCheckBox"
                                                  Content="Use prior population information" />
                                    </GroupBox.Header>

                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <Label x:Name="gensbackLabel"
                                                   Content="Gensback"
                                                   DockPanel.Dock="Left" />
                                            <xctk:IntegerUpDown x:Name="gensbackIntUpDown"
                                                                DockPanel.Dock="Right"
                                                                Minimum="0"
                                                                Maximum="32738"
                                                                Increment="1" />
                                        </DockPanel>
                                        <DockPanel LastChildFill="False">
                                            <Label x:Name="migpriorLabel"
                                                   Content="Migprior"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="migpriorDoubleUpDown"
                                                               DockPanel.Dock="Right"
                                                               Minimum="0"
                                                               Maximum="1"
                                                               Increment="0.01"
                                                               FormatString="0.##" />
                                        </DockPanel>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>

                            <GroupBox x:Name="admixtureModelGroupBox"
                                      Header="Admixture model"
                                      Grid.Row="1"
                                      Grid.Column="2"
                                      Margin="0,0,0,0"
                                      HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="setAlphaCheckBox"
                                                  Content="Set alpha"
                                                  Grid.Column="0" />
                                        <CheckBox x:Name="inferAlphaCheckBox"
                                                  Content="Infer alpha"
                                                  Margin="50,0,0,0"
                                                  Grid.Column="1" />
                                    </Grid>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <xctk:DoubleUpDown x:Name="setAlphaDoubleUpDown"
                                                           Minimum="-27000"
                                                           Maximum="27000"
                                                           Increment="0.1"
                                                           Margin="15,0,0,0"
                                                           Grid.Column="0" />

                                        <Label x:Name="alphaInitLabel"
                                               Content="Alpha initialization"
                                               Margin="50,0,0,0"
                                               Grid.Column="1"
                                               HorizontalAlignment="Left" />
                                        <xctk:DoubleUpDown x:Name="alphaInitDoubleUpDown"
                                                           Minimum="-27000"
                                                           Maximum="27000"
                                                           Increment="0.1"
                                                           Grid.Column="1"
                                                           HorizontalAlignment="Right" />
                                    </Grid>

                                    <CheckBox x:Name="useUniformPriorCheckBox"
                                              Content="Use a uniform prior for alpha"
                                              Grid.Row="4"
                                              Margin="0,10,0,0" />

                                    <Grid Grid.Row="5"
                                          Margin="0"
                                          Grid.RowSpan="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <DockPanel LastChildFill="False"
                                                   Grid.Column="0"
                                                   Grid.Row="0"
                                                   Margin="0">
                                            <Label x:Name="alphaMaxLabel"
                                                   Content="Alpha max"
                                                   Margin="15,0,0,0"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="alphaMaxDoubleUpDown"
                                                               DockPanel.Dock="Right"
                                                               Minimum="0"
                                                               Maximum="32768"
                                                               Increment="0.1" />
                                        </DockPanel>

                                        <DockPanel LastChildFill="False"
                                                   Grid.Column="1"
                                                   Grid.Row="0">
                                            <Label x:Name="alphaPriorALabel"
                                                   Content="Alphapriora"
                                                   Margin="25,0,0,0"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="alphaPriorADoubleUpDown"
                                                               DockPanel.Dock="Right"
                                                               Minimum="0"
                                                               Maximum="100"
                                                               Increment="0.01"
                                                               FormatString="0.##" />
                                        </DockPanel>

                                        <DockPanel LastChildFill="False"
                                                   Grid.Column="0"
                                                   Grid.Row="1"
                                                   Margin="0">
                                            <Label x:Name="alphaPropSdLabel"
                                                   Content="Alpha propsd"
                                                   Margin="15,0,0,0"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="alphaPropSdDoubleUpDown"
                                                               DockPanel.Dock="Right"
                                                               Minimum="0"
                                                               Maximum="100"
                                                               Increment="0.001"
                                                               FormatString="0.###"
                                                               Width="70" />
                                        </DockPanel>

                                        <DockPanel LastChildFill="False"
                                                   Grid.Column="1"
                                                   Grid.Row="1">
                                            <Label x:Name="alphaPriorBLabel"
                                                   Content="Alphapriorb"
                                                   Margin="25,0,0,0"
                                                   DockPanel.Dock="Left" />
                                            <xctk:DoubleUpDown x:Name="alphaPriorBDoubleUpDown"
                                                               DockPanel.Dock="Right"
                                                               Minimum="0"
                                                               Maximum="100"
                                                               Increment="0.001"
                                                               FormatString="0.###" />
                                        </DockPanel>
                                    </Grid>

                                    <CheckBox x:Name="popAlphaSeparationCheckBox"
                                              Content="Separate alpha by population"
                                              Grid.Row="2"
                                              HorizontalAlignment="Center"
                                              Margin="79,0,0,0" />

                                    <DockPanel Grid.Row="3"
                                               LastChildFill="False">
                                        <Label x:Name="preburninLengthLabel"
                                               Content="Length of pre-burnin period"
                                               DockPanel.Dock="Left" />
                                        <xctk:IntegerUpDown x:Name="preburninLengthIntUpDown"
                                                            DockPanel.Dock="Right"
                                                            Minimum="0"
                                                            Maximum="100"
                                                            Increment="1" />
                                    </DockPanel>
                                </Grid>
                            </GroupBox>
                        </Grid>
                    </GroupBox>

                    <GroupBox x:Name="advancedGroupBox"
                              Header="Advanced"
                              Grid.Row="3"
                              Grid.Column="0"
                              Grid.ColumnSpan="2"
                              HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <CheckBox x:Name="estimateProbabilityCheckBox"
                                      Content="Estimate the probability of the data"
                                      Grid.Row="0"
                                      Grid.Column="0" />
                            <CheckBox x:Name="printLikelihoodCheckBox"
                                      Content="Print the current value of the likelihood to screen"
                                      Grid.Row="1"
                                      Grid.Column="0" />
                            <CheckBox x:Name="popinfoInitCheckBox"
                                      Content="Initialize at POPINFO"
                                      Grid.Row="2"
                                      Grid.Column="0" />
                            <CheckBox x:Name="printCredibleRegionsCheckBox"
                                      Content="Print credible regions"
                                      Grid.Row="3"
                                      Grid.Column="0" />
                            <StackPanel Orientation="Horizontal"
                                        Grid.Row="4"
                                        Grid.Column="0">

                                <Label x:Name="numboxesLabel"
                                       Content="Numboxes"
                                       Margin="15,0,0,0"
                                       DockPanel.Dock="Left" />
                                <xctk:IntegerUpDown x:Name="numboxesIntUpDown"
                                                    Minimum="1"
                                                    Maximum="32768"
                                                    Increment="1"
                                                    DockPanel.Dock="Right" />

                                <Label x:Name="ancestpintLabel"
                                       Content="Ancestpint"
                                       Margin="15,0,0,0"
                                       DockPanel.Dock="Left" />
                                <xctk:DoubleUpDown x:Name="ancestpintDoubleUpDown"
                                                   Minimum="0"
                                                   Maximum="1"
                                                   Increment="0.01"
                                                   FormatString="0.##"
                                                   DockPanel.Dock="Right" />

                            </StackPanel>

                            <CheckBox x:Name="printLambdaCheckBox"
                                      Content="Print current value of lambda"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Margin="10,0,0,0" />
                            <CheckBox x:Name="printQEstimatesSumCheckBox"
                                      Content="Print summary of current Q estimates to screen"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="10,0,0,0" />
                            <CheckBox x:Name="printQhatCheckBox"
                                      Content="Print Q-hat"
                                      Grid.Row="2"
                                      Grid.Column="1"
                                      Margin="10,0,0,0" />
                            <CheckBox x:Name="printNucleotideDistCheckBox"
                                      Content="Print the &quot;net nucleotide distance&quot;"
                                      Grid.Row="3"
                                      Grid.Column="1"
                                      Margin="10,0,0,0" />
                            <DockPanel LastChildFill="False"
                                       Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="10,0,0,0">
                                <Label x:Name="printFreqLabel"
                                       Content="Freq. of printing updates"
                                       DockPanel.Dock="Left" />
                                <xctk:IntegerUpDown x:Name="printFreqIntUpDown"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    Increment="1"
                                                    DockPanel.Dock="Right" />
                            </DockPanel>

                            <CheckBox x:Name="saveIntermediateCheckBox"
                                      Content="Save intermediate data"
                                      Grid.Row="0"
                                      Grid.Column="2"
                                      Margin="10,0,0,0" />
                            <CheckBox x:Name="printSetBriefSumCheckBox"
                                      Content="Print a brief summary of the data set"
                                      Grid.Row="1"
                                      Grid.Column="2"
                                      Margin="10,0,0,0" />
                            <CheckBox x:Name="showHitRateCheckBox"
                                      Content="Show hit rate"
                                      Grid.Row="2"
                                      Grid.Column="2"
                                      Margin="10,0,0,0" />
                            <DockPanel Grid.Row="3"
                                       Grid.Column="2"
                                       LastChildFill="False"
                                       Margin="10,0,0,0">
                                <CheckBox x:Name="randomSeedCheckBox"
                                          Content="Use a random seed"
                                          DockPanel.Dock="Left" />
                                <xctk:IntegerUpDown x:Name="seedIntUpDown"
                                                    Minimum="0"
                                                    Maximum="32768"
                                                    Increment="1"
                                                    DockPanel.Dock="Right" />
                            </DockPanel>
                            <DockPanel LastChildFill="False"
                                       Grid.Row="4"
                                       Grid.Column="2"
                                       Margin="10,0,0,0">
                                <Label x:Name="metropolisStepFreqLabel"
                                       Content="Freq. of metropolis step to update Q"
                                       DockPanel.Dock="Left" />
                                <xctk:IntegerUpDown x:Name="metropolisStepFreqIntUpDown"
                                                    Minimum="1"
                                                    Maximum="32768"
                                                    Increment="1"
                                                    DockPanel.Dock="Right" />
                            </DockPanel>
                        </Grid>
                    </GroupBox>

                    <StackPanel Grid.Column="0"
                                Grid.Row="4"
                                Orientation="Horizontal"
                                Grid.ColumnSpan="2">
