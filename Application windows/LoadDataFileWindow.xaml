<Window x:Class="GenotypeApplication.Application_windows.LoadDataFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GenotypeApplication.Application_windows"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Load data file"
        Height="638"
        Width="412.5"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto"
                              x:Name="inputDataGridColumn" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox x:Name="selectDataFileGroupBox"
                  Header="Select input data file"
                  Grid.Row="0"
                  Grid.Column="0">
            <StackPanel x:Name="dataFilePathStackPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Stretch">

                <Grid Width="230.36">
                    <TextBox x:Name="dataFilePathTextBox"
                             FontWeight="Light"
                             Width="230.36"
                             Text="{Binding DataFileFullPath, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Data file path"
                               Foreground="LightGray"
                               Margin="5,0,0,1"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=dataFilePathTextBox}"
                                                 Value="">
                                        <Setter Property="Visibility"
                                                Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>


                <Button x:Name="selectDataFileButton"
                        Content="Select"
                        Style="{StaticResource Rounded}"
                        Margin="10,0,0,0"
                        Command="{Binding SelectDataFileCommand}" />
            </StackPanel>
        </GroupBox>

        <GroupBox x:Name="dataFileOptionsGroupBox"
                  Header="Input data file options"
                  Grid.Row="1"
                  Grid.Column="0">
            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{Binding IsPathValid, UpdateSourceTrigger=PropertyChanged}">
                <GroupBox x:Name="dataSetInfoGroupBox"
                          Header="Information of input data set"
                          HorizontalAlignment="Stretch">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Label x:Name="individsNumLabel"
                               Content="Number of individuals"
                               Grid.Row="0"
                               Grid.Column="0" />
                        <xctk:IntegerUpDown x:Name="individsNumIntUpDown"
                                            Minimum="0"
                                            Maximum="32768"
                                            Increment="1"
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Value="{Binding NumIndsParam, UpdateSourceTrigger=PropertyChanged}" />

                        <Label x:Name="lociNumLabel"
                               Content="Number of loci"
                               Grid.Row="1"
                               Grid.Column="0" />
                        <xctk:IntegerUpDown x:Name="lociNumIntUpDown"
                                            Minimum="0"
                                            Maximum="32768"
                                            Increment="1"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Value="{Binding NumLociParam, UpdateSourceTrigger=PropertyChanged}" />

                        <Label x:Name="ploidyDataLabel"
                               Content="Ploidy of data"
                               Grid.Row="2"
                               Grid.Column="0" />
                        <xctk:IntegerUpDown x:Name="ploidyDataIntUpDown"
                                            Minimum="1"
                                            Maximum="32768"
                                            Increment="1"
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Value="{Binding PloidyParam, UpdateSourceTrigger=PropertyChanged}" />

                        <Label x:Name="missingDataLabel"
                               Content="Missing data value"
                               Grid.Row="3"
                               Grid.Column="0" />
                        <xctk:IntegerUpDown x:Name="missingDataIntUpDown"
                                            Minimum="-999"
                                            Maximum="999"
                                            Increment="1"
                                            Grid.Row="3"
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Value="{Binding MissingParam, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <GroupBox x:Name="dataSetFormatGroupBox"
                          Header="Format of input data set">
                    <StackPanel Orientation="Vertical"
                                HorizontalAlignment="Stretch">
                        <GroupBox x:Name="rowsFormatGroupBox"
                                  Header="Please check box if data file contains following row(s)"
                                  HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Vertical">
                                <CheckBox x:Name="markerRowCheckBox"
                                          Content="Marker names row"
                                          IsChecked="{Binding MarkerNamesParam, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox x:Name="recessiveAllelesRowCheckBox"
                                          Content="Recessive alleles row"
                                          IsChecked="{Binding RecessiveAllelesParam, UpdateSourceTrigger=PropertyChanged}" />
                                <GroupBox x:Name="noneAmbiguousGenotypesGroupBox"
                                          Padding="0"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="{Binding IsChecked, ElementName=recessiveAllelesRowCheckBox}">
                                    <GroupBox.Header>
                                        <CheckBox x:Name="noneAmbiguousGenotypesCheckBox"
                                                  Content="Exclude unambiguous genotypes from analysis"
                                                  IsChecked="{Binding NotAmbiguousParam, UpdateSourceTrigger=PropertyChanged}" />
                                    </GroupBox.Header>

                                    <DockPanel LastChildFill="False"
                                               IsEnabled="{Binding IsChecked, ElementName=noneAmbiguousGenotypesCheckBox}">
                                        <Label Content="Unambiguous code value"
                                               DockPanel.Dock="Left" />
                                        <xctk:IntegerUpDown x:Name="noneAmbiguousGenotypesIntUpDown"
                                                            DockPanel.Dock="Right"
                                                            Minimum="-9999"
                                                            Maximum="9999"
                                                            Increment="1"
                                                            Value="{Binding NotAmbiguousValueParam, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                </GroupBox>
                                <CheckBox x:Name="mapDistancesRowCheckBox"
                                          Content="Map distances between loci row"
                                          IsChecked="{Binding MapDistancesParam, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox x:Name="phaseInfoRowCheckBox"
                                          Content="Phase info"
                                          IsChecked="{Binding PhaseInfoParam, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox x:Name="singleLineIndividsCheckBox"
                                          Content="Data for individuals are in a single line"
                                          IsChecked="{Binding OneRowPerIndFileParam, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox x:Name="columnsFormatGroupBox"
                                  Header="Please check box if data file contains following column(s)">
                            <StackPanel Orientation="Vertical">
                                <CheckBox x:Name="individsIdColumnCheckBox"
                                          Content="ID for each individual"
                                          IsChecked="{Binding LabelParam, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox x:Name="allegedOriginsColumnCheckBox"
                                          Content="Alleged population origin of each individual"
                                          IsChecked="{Binding PopDataParam, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox x:Name="popInfoFlagsColumnCheckBox"
                                          Content="USEPOPINFO flag"
                                          IsChecked="{Binding PopFlagParam, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox x:Name="locationsInfoColumnCheckBox"
                                          Content="Sampling location information"
                                          IsChecked="{Binding LocDataParam, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox x:Name="phenotypesInfoColumnCheckBox"
                                          Content="Phenotype information"
                                          IsChecked="{Binding PhenotypeParam, UpdateSourceTrigger=PropertyChanged}" />
                                <DockPanel LastChildFill="False">
                                    <CheckBox x:Name="extraColumnsCheckBox"
                                              Content="Other extra colums"
                                              DockPanel.Dock="Left"
                                              IsChecked="{Binding ExtraColsParam, UpdateSourceTrigger=PropertyChanged}" />
                                    <xctk:IntegerUpDown x:Name="extraColumnsNumIntUpDown"
                                                        Minimum="0"
                                                        Maximum="32768"
                                                        Increment="1"
                                                        Margin="5,0,0,0"
                                                        DockPanel.Dock="Right"
                                                        IsEnabled="{Binding IsChecked, ElementName=extraColumnsCheckBox}"
                                                        Value="{Binding ExtraColsCountParam, UpdateSourceTrigger=PropertyChanged}" />
                                    <Label x:Name="extraColumnsNumLabel"
                                           Content="in quantity"
                                           DockPanel.Dock="Right"
                                           IsEnabled="{Binding IsChecked, ElementName=extraColumnsCheckBox}" />
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </GroupBox>

        <ToggleButton Style="{StaticResource ExpanderToggle}"
                      Grid.Row="1"
                      Grid.Column="1"
                      VerticalAlignment="Stretch"
                      Margin="5,5,0,0"
                      Width="20"
                      Checked="ToggleButton_Checked"
                      Unchecked="ToggleButton_Unchecked" />

        <GroupBox x:Name="inputDataGridGroupBox"
                  Header="Data viewer"
                  Grid.Row="1"
                  Grid.Column="2"
                  Height="488"
                  Width="630"
                  Margin="1,0,5,0">

            <DataGrid x:Name="inputDataGrid"
                      ItemsSource="{Binding DataTableSource.DefaultView, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      BorderThickness="0"
                      IsReadOnly="True"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      CanUserResizeColumns="True"
                      CanUserResizeRows="True"
                      CanUserReorderColumns="False"
                      GridLinesVisibility="All"
                      BorderBrush="Transparent"
                      Background="Transparent"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserSortColumns="False"
                      AutoGenerateColumns="True"
                      HeadersVisibility="None">
            </DataGrid>
        </GroupBox>

        <Button x:Name="saveDataSetOptionsButton"
                Content="Save"
                Grid.Row="2"
                Grid.Column="0"
                HorizontalAlignment="Right"
                Style="{StaticResource Rounded}" />
    </Grid>
</Window>
